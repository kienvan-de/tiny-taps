---
export const prerender = false;
import PublicLayout from '../layouts/PublicLayout.astro';
import HomeDashboard from '../components/HomeDashboard.svelte';
import LangPicker from '../components/LangPicker.svelte';
import PawPrint from 'phosphor-astro/PawPrintBold.astro';
import { DEFAULT_LOCALE, isValidLocale } from '../lib/i18n';

// Read locale from cookie (set by LangPicker on client)
const cookieLocale = Astro.cookies.get('tt-locale')?.value;
const initialLocale = isValidLocale(cookieLocale) ? cookieLocale : DEFAULT_LOCALE;
---
<PublicLayout title="Tiny Taps">
  <div class="dashboard">

    <!-- ── Top bar ─────────────────────────────────────────────────────── -->
    <header class="top-bar">
      <div class="brand">
        <span class="brand-icon"><PawPrint color="#FF4B4B" /></span>
        <span class="brand-name">Tiny Taps</span>
      </div>
      <LangPicker
        client:load
        locale={initialLocale}
      />
    </header>

    <!-- ── Client-side dashboard ──────────────────────────────────────── -->
    <HomeDashboard client:load locale={initialLocale} />

  </div>
</PublicLayout>

<style>
  .dashboard {
    min-height: 100vh;
    background: #FFF9E6;
    display: flex;
    flex-direction: column;
  }

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px 8px;
    flex-shrink: 0;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    user-select: none;
  }

  .brand-icon,
  .brand-icon :global(svg) {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: 'Nunito', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: #4A4A4A;
    letter-spacing: -0.5px;
  }
</style>
