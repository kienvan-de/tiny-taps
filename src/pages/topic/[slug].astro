---
import PublicLayout from '../../layouts/PublicLayout.astro';
import NavHome from '../../components/NavHome.svelte';
import TopicPlayer from '../../components/TopicPlayer.svelte';
import { env as cfEnv } from 'cloudflare:workers';

export async function getStaticPaths() {
  const result = await cfEnv.DB.prepare('SELECT slug FROM topics').all<{ slug: string }>();
  return (result.results ?? []).map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const env = cfEnv as App.Locals['env'];

// Fetch just the topic title for the page <title> and header — lightweight, no subjects needed
const topic = await env.DB.prepare('SELECT title FROM topics WHERE slug = ?')
  .bind(slug)
  .first<{ title: string }>();

if (!topic) return Astro.redirect('/');
---
<PublicLayout title={`${topic.title} — Tiny Taps`} viewportLock={true}>
  <div class="play-page">

    <!-- ── Top bar ──────────────────────────────────────────────────────── -->
    <header class="play-header">
      <NavHome client:load href="/" />
      <h1 class="topic-title">{topic.title.toUpperCase()}</h1>
      <div class="header-spacer" aria-hidden="true"></div>
    </header>

    <!-- ── Subject area — fully client-side via TopicPlayer island ──────── -->
    <main class="subject-area">
      <TopicPlayer client:load slug={slug} />
    </main>

  </div>
</PublicLayout>

<style>
  /* ── Full-viewport play page ────────────────────────────────────────── */
  .play-page {
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #FFF9E6;
    box-sizing: border-box;
  }

  /* ── Top bar ──────────────────────────────────────────────────────────── */
  .play-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    flex-shrink: 0;
    gap: 12px;
  }

  .topic-title {
    font-family: 'Nunito', sans-serif;
    font-size: clamp(20px, 5vw, 48px);
    font-weight: 800;
    color: #4A4A4A;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    flex: 1;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .header-spacer {
    width: 100px;
    flex-shrink: 0;
  }

  /* ── Subject area ─────────────────────────────────────────────────────── */
  .subject-area {
    flex: 1;
    min-height: 0;
    padding: 8px 20px 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Make TopicPlayer island fill the subject area */
  .subject-area > :global(*) {
    width: 100%;
    height: 100%;
    flex: 1;
    min-height: 0;
  }
</style>
