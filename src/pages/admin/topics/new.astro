---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const env = Astro.locals.env;
const tags = await env.DB.prepare('SELECT * FROM tags ORDER BY sort_order ASC, name ASC').all();
---
<AdminLayout title="New Topic">
  <style>
    .form-wrapper {
      max-width: 640px;
      width: 100%;
    }

    .form-card {
      background: white;
      border-radius: 12px;
      padding: 32px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .form-actions {
      display: flex;
      gap: 12px;
      align-items: center;
      padding-top: 8px;
      border-top: 1px solid #f1f5f9;
    }

    @media (max-width: 768px) {
      .form-card {
        padding: 20px 16px;
      }

      .form-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .form-actions #submitBtn {
        width: 100%;
      }

      .form-actions .cancel-link {
        width: 100%;
        text-align: center;
      }
    }
  </style>

  <div class="form-wrapper">
    <div class="form-card">
      <form id="newTopicForm">
        <div style="margin-bottom:20px;">
          <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">
            Title <span style="color:#ef4444;">*</span>
          </label>
          <input
            name="title"
            id="titleInput"
            required
            placeholder="e.g. Farm Animals"
            style="width:100%; border:1.5px solid #cbd5e1; border-radius:8px; padding:11px 14px; font-size:16px; font-family:inherit; outline:none; transition:border-color 0.15s;"
            onfocus="this.style.borderColor='#4BA3FF'"
            onblur="this.style.borderColor='#cbd5e1'"
          />
        </div>

        <div style="margin-bottom:20px;">
          <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:6px;">
            Slug
          </label>
          <input
            name="slug"
            id="slugInput"
            placeholder="auto-generated from title"
            style="width:100%; border:1.5px solid #cbd5e1; border-radius:8px; padding:11px 14px; font-size:15px; font-family:'Courier New',monospace; outline:none; transition:border-color 0.15s; color:#475569;"
            onfocus="this.style.borderColor='#4BA3FF'"
            onblur="this.style.borderColor='#cbd5e1'"
          />
          <div style="font-size:12px; color:#94a3b8; margin-top:4px;">
            Will be used in the URL: /topic/<strong id="slugPreview">your-slug</strong>
          </div>
        </div>

        {tags.results.length > 0 && (
          <div style="margin-bottom:24px;">
            <label style="display:block; font-size:13px; font-weight:700; color:#475569; margin-bottom:10px;">
              Tags
            </label>
            <div style="display:flex; flex-wrap:wrap; gap:8px;">
              {(tags.results as any[]).map((tag) => (
                <label style="display:flex; align-items:center; gap:6px; cursor:pointer; padding:6px 14px; border:1.5px solid #e2e8f0; border-radius:20px; font-size:14px; font-weight:700; transition:all 0.15s; user-select:none;"
                  onmouseover="this.style.borderColor='#4BA3FF'; this.style.background='#eff8ff'"
                  onmouseout="if(!this.querySelector('input').checked){this.style.borderColor='#e2e8f0'; this.style.background='white'}"
                >
                  <input
                    type="checkbox"
                    name="tag_ids"
                    value={tag.id}
                    style="display:none;"
                    onchange="updateTagStyle(this)"
                  />
                  <span style={`display:inline-block; padding:1px 8px; border-radius:20px; font-size:12px; background:${tag.category === 'age' ? '#e0f2fe' : '#dcfce7'}; color:${tag.category === 'age' ? '#0369a1' : '#166534'};`}>
                    {tag.category}
                  </span>
                  {tag.name}
                </label>
              ))}
            </div>
          </div>
        )}

        <div class="form-actions">
          <button
            type="submit"
            id="submitBtn"
            style="background:#4BA3FF; color:white; border:none; border-radius:8px; padding:11px 24px; font-size:15px; font-weight:800; font-family:inherit; cursor:pointer; transition:background 0.15s; min-height:44px;"
            onmouseover="this.style.background='#2f8de8'"
            onmouseout="this.style.background='#4BA3FF'"
          >
            Create Topic
          </button>
          <a
            href="/admin/topics"
            class="cancel-link"
            style="padding:11px 20px; font-size:15px; font-weight:700; color:#64748b; text-decoration:none;"
          >
            Cancel
          </a>
          <div id="errorMsg" style="color:#ef4444; font-size:14px; font-weight:700; display:none; margin-left:8px;"></div>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    const titleInput = document.getElementById('titleInput');
    const slugInput = document.getElementById('slugInput');
    const slugPreview = document.getElementById('slugPreview');
    const form = document.getElementById('newTopicForm');
    const submitBtn = document.getElementById('submitBtn');
    const errorMsg = document.getElementById('errorMsg');

    let slugManuallyEdited = false;

    function toSlug(text) {
      return text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    titleInput.addEventListener('input', (e) => {
      if (!slugManuallyEdited) {
        const slug = toSlug(e.target.value);
        slugInput.value = slug;
        slugPreview.textContent = slug || 'your-slug';
      }
    });

    slugInput.addEventListener('input', (e) => {
      slugManuallyEdited = e.target.value.length > 0;
      slugPreview.textContent = e.target.value || 'your-slug';
    });

    function updateTagStyle(checkbox) {
      const label = checkbox.closest('label');
      if (checkbox.checked) {
        label.style.borderColor = '#4BA3FF';
        label.style.background = '#eff8ff';
        label.style.color = '#0369a1';
      } else {
        label.style.borderColor = '#e2e8f0';
        label.style.background = 'white';
        label.style.color = '';
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.style.display = 'none';

      const title = titleInput.value.trim();
      if (!title) {
        errorMsg.textContent = 'Title is required.';
        errorMsg.style.display = 'block';
        titleInput.focus();
        return;
      }

      const slug = slugInput.value.trim() || toSlug(title);
      const tagCheckboxes = form.querySelectorAll('input[name="tag_ids"]:checked');
      const tag_ids = Array.from(tagCheckboxes).map(cb => cb.value);

      submitBtn.disabled = true;
      submitBtn.textContent = 'Creating…';

      try {
        const res = await fetch('/api/admin/topics', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, slug, tag_ids }),
        });

        if (res.ok) {
          const topic = await res.json();
          window.location.href = `/admin/topics/${topic.id}/subjects`;
        } else {
          const err = await res.json().catch(() => ({}));
          errorMsg.textContent = err.error ?? 'Failed to create topic.';
          errorMsg.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Create Topic';
        }
      } catch {
        errorMsg.textContent = 'Network error. Please try again.';
        errorMsg.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Topic';
      }
    });
  </script>
</AdminLayout>
