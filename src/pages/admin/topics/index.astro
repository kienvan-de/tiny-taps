---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const env = Astro.locals.env;
const topics = await env.DB.prepare(`
  SELECT t.*, (SELECT COUNT(*) FROM subjects s WHERE s.topic_id = t.id) AS subject_count
  FROM topics t
  ORDER BY t.created_at DESC
`).all();

const topicTagsMap: Record<string, { id: string; name: string; category: string }[]> = {};
for (const topic of topics.results as any[]) {
  const tags = await env.DB.prepare(
    'SELECT tg.* FROM tags tg JOIN topic_tags tt ON tt.tag_id = tg.id WHERE tt.topic_id = ? ORDER BY tg.sort_order ASC'
  ).bind(topic.id).all();
  topicTagsMap[topic.id] = tags.results as any[];
}
---
<AdminLayout title="Topics">
  <div style="margin-bottom:20px; display:flex; justify-content:space-between; align-items:center;">
    <span style="color:#64748b; font-size:14px;">{topics.results.length} topic{topics.results.length !== 1 ? 's' : ''}</span>
    <a
      href="/admin/topics/new"
      style="background:#4BA3FF; color:white; padding:10px 20px; border-radius:8px; text-decoration:none; font-weight:800; font-size:15px;"
    >
      + New Topic
    </a>
  </div>

  <div style="background:white; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden;">
    {topics.results.length === 0 ? (
      <div style="text-align:center; color:#94a3b8; padding:60px 0; font-size:15px;">
        No topics yet.
        <a href="/admin/topics/new" style="color:#4BA3FF; font-weight:700; margin-left:4px;">Create your first topic →</a>
      </div>
    ) : (
      <>
        {/* Desktop table — hidden on mobile */}
        <table class="topics-table" style="width:100%; border-collapse:collapse;">
          <thead>
            <tr style="border-bottom:2px solid #f1f5f9; background:#f8fafc;">
              <th style="text-align:left; padding:12px 16px; font-size:13px; font-weight:700; color:#64748b;">Title</th>
              <th style="text-align:left; padding:12px 16px; font-size:13px; font-weight:700; color:#64748b;">Slug</th>
              <th style="text-align:left; padding:12px 16px; font-size:13px; font-weight:700; color:#64748b;">Tags</th>
              <th style="text-align:center; padding:12px 16px; font-size:13px; font-weight:700; color:#64748b;">Subjects</th>
              <th style="padding:12px 16px;"></th>
            </tr>
          </thead>
          <tbody>
            {(topics.results as any[]).map((t) => (
              <tr style="border-bottom:1px solid #f8fafc; transition:background 0.1s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                <td style="padding:12px 16px;">
                  <span style="font-size:15px; font-weight:800; color:#1e293b;">{t.title}</span>
                </td>
                <td style="padding:12px 16px;">
                  <code style="font-size:13px; background:#f1f5f9; padding:2px 8px; border-radius:4px; color:#475569;">{t.slug}</code>
                </td>
                <td style="padding:12px 16px;">
                  <div style="display:flex; flex-wrap:wrap; gap:4px;">
                    {topicTagsMap[t.id]?.length > 0 ? topicTagsMap[t.id].map((tag) => (
                      <span style={`display:inline-block; padding:2px 8px; border-radius:20px; font-size:12px; font-weight:700; background:${tag.category === 'age' ? '#e0f2fe' : '#dcfce7'}; color:${tag.category === 'age' ? '#0369a1' : '#166534'};`}>
                        {tag.name}
                      </span>
                    )) : (
                      <span style="color:#cbd5e1; font-size:13px;">—</span>
                    )}
                  </div>
                </td>
                <td style="padding:12px 16px; text-align:center;">
                  <span style="font-size:15px; font-weight:700; color:#1e293b;">{t.subject_count}</span>
                </td>
                <td style="padding:12px 16px;">
                  <div style="display:flex; gap:6px; justify-content:flex-end;">
                    <a
                      href={`/topic/${t.slug}`}
                      target="_blank"
                      style="background:#f1f5f9; color:#475569; padding:5px 12px; border-radius:6px; font-size:13px; font-weight:700; text-decoration:none;"
                      title="Preview"
                    >
                      ↗
                    </a>
                    <a
                      href={`/admin/topics/${t.id}/subjects`}
                      style="background:#dcfce7; color:#166534; padding:5px 12px; border-radius:6px; font-size:13px; font-weight:700; text-decoration:none;"
                    >
                      Subjects
                    </a>
                    <a
                      href={`/admin/topics/${t.id}/edit`}
                      style="background:#e0f2fe; color:#0369a1; padding:5px 12px; border-radius:6px; font-size:13px; font-weight:700; text-decoration:none;"
                    >
                      Edit
                    </a>
                    <button
                      onclick={`deleteTopic('${t.id}', '${t.title.replace(/'/g, "\\'")}')`}
                      style="background:#fee2e2; color:#ef4444; border:none; border-radius:6px; padding:5px 12px; font-size:13px; font-weight:700; font-family:inherit; cursor:pointer;"
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        {/* Mobile cards — hidden on desktop */}
        <div class="topics-cards">
          {(topics.results as any[]).map((t) => (
            <div class="topic-card">
              <div class="topic-card-header">
                <span class="topic-card-title">{t.title}</span>
                <span class="topic-card-count-badge">{t.subject_count} subject{t.subject_count !== 1 ? 's' : ''}</span>
              </div>

              <code class="topic-card-slug">{t.slug}</code>

              <div class="topic-card-tags">
                {topicTagsMap[t.id]?.length > 0 ? topicTagsMap[t.id].map((tag) => (
                  <span class={`topic-tag topic-tag--${tag.category}`}>
                    {tag.name}
                  </span>
                )) : (
                  <span class="topic-tag-empty">No tags</span>
                )}
              </div>

              <div class="topic-card-actions">
                <a
                  href={`/topic/${t.slug}`}
                  target="_blank"
                  class="topic-action-btn topic-action-btn--preview"
                  title="Preview"
                >
                  ↗ Preview
                </a>
                <a
                  href={`/admin/topics/${t.id}/subjects`}
                  class="topic-action-btn topic-action-btn--subjects"
                >
                  Subjects
                </a>
                <a
                  href={`/admin/topics/${t.id}/edit`}
                  class="topic-action-btn topic-action-btn--edit"
                >
                  Edit
                </a>
                <button
                  onclick={`deleteTopic('${t.id}', '${t.title.replace(/'/g, "\\'")}')`}
                  class="topic-action-btn topic-action-btn--delete"
                >
                  Delete
                </button>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>

  <script>
  // @ts-nocheck
    async function deleteTopic(id: string, title: string) {
      if (!confirm(`Delete "${title}" and all its subjects and sounds?`)) return;

      const res = await fetch('/api/admin/topics', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert('Failed to delete topic');
      }
    }

    window.deleteTopic = deleteTopic;
  </script>
</AdminLayout>

<style>
  /* ── Mobile cards: hidden by default (desktop shows table) ── */
  .topics-cards {
    display: none;
  }

  /* ── Responsive breakpoint ── */
  @media (max-width: 768px) {
    /* Hide desktop table */
    .topics-table {
      display: none;
    }

    /* Show mobile cards */
    .topics-cards {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* Individual card */
    .topic-card {
      padding: 16px;
      border-bottom: 1px solid #f1f5f9;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .topic-card:last-child {
      border-bottom: none;
    }

    /* Header row: title + subject count badge */
    .topic-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
    }

    .topic-card-title {
      font-size: 16px;
      font-weight: 800;
      color: #1e293b;
      line-height: 1.3;
    }

    .topic-card-count-badge {
      display: inline-block;
      background: #f1f5f9;
      color: #475569;
      font-size: 12px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      white-space: nowrap;
    }

    /* Slug pill */
    .topic-card-slug {
      display: inline-block;
      font-size: 12px;
      background: #f1f5f9;
      padding: 3px 10px;
      border-radius: 4px;
      color: #475569;
      word-break: break-all;
    }

    /* Tags row */
    .topic-card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .topic-tag {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
    }

    .topic-tag--age {
      background: #e0f2fe;
      color: #0369a1;
    }

    .topic-tag--subject,
    .topic-tag--topic,
    .topic-tag--default {
      background: #dcfce7;
      color: #166534;
    }

    /* Fallback for any non-age category */
    .topic-tag:not(.topic-tag--age) {
      background: #dcfce7;
      color: #166534;
    }

    .topic-tag-empty {
      color: #cbd5e1;
      font-size: 13px;
    }

    /* Action buttons row */
    .topic-card-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .topic-action-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      font-family: inherit;
      text-decoration: none;
      border: none;
      cursor: pointer;
      flex: 1 1 auto;
      text-align: center;
    }

    .topic-action-btn--preview {
      background: #f1f5f9;
      color: #475569;
    }

    .topic-action-btn--subjects {
      background: #dcfce7;
      color: #166534;
    }

    .topic-action-btn--edit {
      background: #e0f2fe;
      color: #0369a1;
    }

    .topic-action-btn--delete {
      background: #fee2e2;
      color: #ef4444;
    }
  }
</style>
