---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import SoundEditor from '../../../../components/SoundEditor.svelte';
import ImageUpload from '../../../../components/ImageUpload.svelte';
import { VOICES, LANGUAGE_LABELS } from '../../../../lib/voices';
import { getPublicUrl } from '../../../../lib/r2';

const { id } = Astro.params;
const env = Astro.locals.env;

const topic = await env.DB.prepare('SELECT * FROM topics WHERE id = ?')
  .bind(id).first<{ id: string; title: string; slug: string }>();

if (!topic) return Astro.redirect('/admin/topics');

const subjects = await env.DB.prepare(
  'SELECT * FROM subjects WHERE topic_id = ? ORDER BY sort_order ASC'
).bind(id).all();

const sounds = await env.DB.prepare(
  `SELECT s.* FROM sounds s
   JOIN subjects sub ON sub.id = s.subject_id
   WHERE sub.topic_id = ?
   ORDER BY s.subject_id, s.sort_order ASC`
).bind(id).all();

// Group sounds by subject_id
const soundsBySubject: Record<string, any[]> = {};
for (const snd of sounds.results as any[]) {
  if (!soundsBySubject[snd.subject_id]) soundsBySubject[snd.subject_id] = [];
  soundsBySubject[snd.subject_id].push(snd);
}

function imageUrl(key: string | null): string | null {
  return key ? getPublicUrl(env, key) : null;
}

const voicesJson = JSON.stringify(VOICES);
const languageLabelsJson = JSON.stringify(LANGUAGE_LABELS);
---

<AdminLayout title={`Subjects: ${topic.title}`}>

  <!-- ── Page header ──────────────────────────────────────── -->
  <div class="page-header">
    <div class="breadcrumb">
      <a href="/admin/topics">← Topics</a>
      <span class="sep">/</span>
      <span>{topic.title}</span>
    </div>
    <div class="header-actions">
      <a href={`/topic/${topic.slug}`} target="_blank" rel="noopener" class="btn btn-ghost">
        ↗ Preview
      </a>
      <button id="addSubjectBtn" class="btn btn-primary">+ Add Subject</button>
    </div>
  </div>

  <!-- ── Subject list ─────────────────────────────────────── -->
  <div id="subjectList">
    {subjects.results.length === 0 && (
      <div id="emptyState" class="empty-state">
        No subjects yet — click <strong>+ Add Subject</strong> to get started.
      </div>
    )}
    {(subjects.results as any[]).map((s, idx) => {
      const sndList: any[] = soundsBySubject[s.id] ?? [];
      return (
        <div class="subject-card" data-id={s.id}>

          <!-- Card header -->
          <div class="card-header">
            <span class="card-num">{idx + 1}</span>
            {s.image_key
              ? <img class="card-thumb" src={imageUrl(s.image_key)!} alt={s.title} />
              : <div class="card-thumb-empty"><i class="ph-bold ph-image"></i></div>
            }
            <div class="card-meta">
              <div class="card-title">{s.title}</div>
              <div class="card-sounds-count">{sndList.length} sound{sndList.length !== 1 ? 's' : ''}</div>
            </div>
            <div class="card-actions">
              <button class="btn btn-sm btn-edit" data-id={s.id}>Edit</button>
              <button class="btn btn-sm btn-danger" data-id={s.id} data-title={s.title}>Delete</button>
            </div>
          </div>

        </div>
      );
    })}
  </div>

  <!-- ── Modal overlay ────────────────────────────────────── -->
  <div id="modalOverlay" class="modal-overlay" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">

      <div class="modal-header">
        <h2 id="modalTitle" class="modal-title">Add Subject</h2>
        <button id="modalCloseBtn" class="modal-close" aria-label="Close">✕</button>
      </div>

      <div class="modal-body">

        <!-- Title -->
        <div class="field">
          <label class="field-label" for="subjectTitle">Name <span class="required">*</span></label>
          <input id="subjectTitle" class="field-input" type="text" placeholder="e.g. Dog" autocomplete="off" />
        </div>

        <!-- Image upload -->
        <div class="field">
          <label class="field-label">Image</label>
          <div class="img-upload-box">
            <div id="imgPreviewWrap" style="display:none;">
              <img id="imgPreview" src="" alt="Preview" class="img-preview" />
              <button type="button" id="imgClearBtn" class="img-clear-btn" title="Remove">✕</button>
            </div>
            <div id="imgPlaceholder" class="img-placeholder">
              <i class="ph-bold ph-image" style="font-size:32px;"></i>
              <span>Click to upload</span>
            </div>
            <input type="file" id="imgFileInput" accept="image/png,image/jpeg,image/webp" style="display:none;" />
            <div id="imgStatus" style="font-size:12px; margin-top:4px; display:none;"></div>
          </div>
        </div>

        <!-- Sounds -->
        <div class="field">
          <div class="sounds-header">
            <label class="field-label" style="margin-bottom:0;">Sounds</label>
            <button type="button" id="addSoundBtn" class="btn btn-sm btn-ghost">+ Add Sound</button>
          </div>
          <div id="soundRows"></div>
          <div id="noSoundsHint" class="no-sounds-hint">No sounds yet — add at least one so the subject plays audio.</div>
        </div>

      </div>

      <div class="modal-footer">
        <button id="modalCancelBtn" class="btn btn-ghost">Cancel</button>
        <button id="modalSaveBtn" class="btn btn-primary">Save Subject</button>
      </div>

    </div>
  </div>

  <!-- ImageUpload Svelte island (hidden, cloned into modal) -->
  <div id="imageUploadTemplate" style="display:none;">
    <ImageUpload client:load prefix="images/subjects" />
  </div>

  <!-- Per-subject SoundEditors for existing subjects -->
  {(subjects.results as any[]).map((s) => (
    <div style="display:none;" data-sound-editor-for={s.id}>
      <SoundEditor client:load subjectId={s.id} voices={VOICES} />
    </div>
  ))}

</AdminLayout>

<script define:vars={{ topicId: id, voicesJson, languageLabelsJson }} is:inline>
// @ts-nocheck
const VOICES = JSON.parse(voicesJson);
const LANGUAGE_LABELS = JSON.parse(languageLabelsJson);

// ── Modal state ───────────────────────────────────────────
let editingSubjectId = null;
let uploadedImageKey = null; // tracks uploaded image key for new subject

// ── DOM refs ──────────────────────────────────────────────
const overlay    = document.getElementById('modalOverlay');
const modalTitle = document.getElementById('modalTitle');
const titleInput = document.getElementById('subjectTitle');
const soundRows  = document.getElementById('soundRows');
const noSoundsHint = document.getElementById('noSoundsHint');
const saveBtn    = document.getElementById('modalSaveBtn');
const addSoundBtn = document.getElementById('addSoundBtn');

// ── Image upload wiring ───────────────────────────────────
const imgFileInput  = document.getElementById('imgFileInput');
const imgClearBtn   = document.getElementById('imgClearBtn');
const imgPreview    = document.getElementById('imgPreview');
const imgPreviewWrap = document.getElementById('imgPreviewWrap');
const imgPlaceholder = document.getElementById('imgPlaceholder');
const imgStatus     = document.getElementById('imgStatus');
imgPlaceholder.addEventListener('click', () => imgFileInput.click());

imgClearBtn.addEventListener('click', () => {
  uploadedImageKey = null;
  imgPreview.src = '';
  imgPreviewWrap.style.display = 'none';
  imgPlaceholder.style.display = 'flex';
  imgStatus.style.display = 'none';
  imgFileInput.value = '';
});

imgFileInput.addEventListener('change', async () => {
  const file = imgFileInput.files?.[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    imgPreview.src = e.target.result;
    imgPreviewWrap.style.display = 'block';
    imgPlaceholder.style.display = 'none';
  };
  reader.readAsDataURL(file);
  // Upload to R2
  imgStatus.textContent = 'Uploading…';
  imgStatus.style.color = '#94a3b8';
  imgStatus.style.display = 'block';
  const fd = new FormData();
  fd.append('file', file);
  fd.append('prefix', 'images/subjects');
  const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
  if (res.ok) {
    const data = await res.json();
    uploadedImageKey = data.key;
    imgStatus.textContent = '✓ Uploaded';
    imgStatus.style.color = '#16a34a';
  } else {
    imgStatus.textContent = '✗ Upload failed';
    imgStatus.style.color = '#ef4444';
    uploadedImageKey = null;
  }
});

function resetImageUpload() {
  uploadedImageKey = null;
  imgPreview.src = '';
  imgPreviewWrap.style.display = 'none';
  imgPlaceholder.style.display = 'flex';
  imgStatus.style.display = 'none';
  imgFileInput.value = '';
}

// ── Open / Close modal ────────────────────────────────────
function openModal(mode = 'add', subject = null) {
  editingSubjectId = subject?.id ?? null;
  modalTitle.textContent = mode === 'edit' ? 'Edit Subject' : 'Add Subject';
  titleInput.value = subject?.title ?? '';
  soundRows.innerHTML = '';
  resetImageUpload();

  if (mode === 'edit' && subject?.sounds?.length) {
    subject.sounds.forEach(s => addSoundRow(s));
  } else {
    addSoundRow();
  }

  updateNoSoundsHint();
  overlay.classList.add('open');
  overlay.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
  setTimeout(() => titleInput.focus(), 50);
}

function closeModal() {
  overlay.classList.remove('open');
  overlay.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
  editingSubjectId = null;
}

// ── Sound rows ────────────────────────────────────────────
let soundCounter = 0;

function addSoundRow(existing = null) {
  const idx = soundCounter++;
  const row = document.createElement('div');
  row.className = 'sound-row';
  row.dataset.idx = idx;

  const defaultLang = existing?.language ?? 'en-US';
  const defaultVoice = existing?.voice ?? VOICES.find(v => v.language === defaultLang)?.id ?? VOICES[0]?.id ?? '';
  const isFile = existing?.type === 'file';

  // Build language options
  const langs = [...new Set(VOICES.map(v => v.language))];
  const langOptions = langs.map(l =>
    `<option value="${l}" ${l === defaultLang ? 'selected' : ''}>${LANGUAGE_LABELS[l] ?? l}</option>`
  ).join('');

  // Build voice options for default lang
  const voiceOptions = VOICES
    .filter(v => v.language === defaultLang)
    .map(v => `<option value="${v.id}" ${v.id === defaultVoice ? 'selected' : ''}>${v.label}</option>`)
    .join('');

  row.innerHTML = `
    <div class="sound-row-header">
      <span class="sound-num">#${soundRows.children.length + 1}</span>
      <select class="sound-type-select field-select">
        <option value="text" ${!isFile ? 'selected' : ''}>Text (TTS)</option>
        <option value="file" ${isFile ? 'selected' : ''}>Audio file</option>
      </select>
      <div class="delay-group">
        <input type="number" class="sound-delay field-input-sm" value="${existing?.delay_before_ms ?? 0}" min="0" step="100" title="Delay before this sound (ms)" />
        <span class="delay-label">ms delay</span>
      </div>
      <button type="button" class="sound-remove-btn" title="Remove sound">✕</button>
    </div>
    <div class="sound-tts-fields" style="${isFile ? 'display:none' : ''}">
      <div>
        <div class="sound-field-label">Text to speak</div>
        <input type="text" class="sound-text field-input" placeholder='e.g. "Dog" or "Woof!"' value="${existing?.text_content ?? ''}" />
      </div>
      <div class="sound-voice-row">
        <label class="sound-voice-label">
          <span class="sound-field-label">Language</span>
          <select class="sound-lang field-select">${langOptions}</select>
        </label>
        <label class="sound-voice-label">
          <span class="sound-field-label">Voice</span>
          <select class="sound-voice field-select">${voiceOptions}</select>
        </label>
      </div>
    </div>
    <div class="sound-file-fields" style="${isFile ? '' : 'display:none'}">
      ${existing?.file_key ? `<div class="file-attached"><i class="ph-bold ph-music-note"></i> ${existing.file_key.split('/').pop()}</div>` : ''}
      <div class="sound-field-label">MP3 file</div>
      <input type="file" class="sound-file-input" accept="audio/mpeg,audio/mp3,.mp3" style="font-size:13px; font-family:inherit;" />
    </div>
  `;

  // Type toggle
  row.querySelector('.sound-type-select').addEventListener('change', (e) => {
    const isTts = e.target.value === 'text';
    row.querySelector('.sound-tts-fields').style.display = isTts ? '' : 'none';
    row.querySelector('.sound-file-fields').style.display = isTts ? 'none' : '';
  });

  // Language → update voices
  row.querySelector('.sound-lang').addEventListener('change', (e) => {
    const lang = e.target.value;
    const voiceSel = row.querySelector('.sound-voice');
    voiceSel.innerHTML = VOICES
      .filter(v => v.language === lang)
      .map(v => `<option value="${v.id}">${v.label}</option>`)
      .join('');
  });

  // Remove button
  row.querySelector('.sound-remove-btn').addEventListener('click', () => {
    row.remove();
    renumberSounds();
    updateNoSoundsHint();
  });

  soundRows.appendChild(row);
  updateNoSoundsHint();
  renumberSounds();
}

function renumberSounds() {
  soundRows.querySelectorAll('.sound-num').forEach((el, i) => {
    el.textContent = `#${i + 1}`;
  });
}

function updateNoSoundsHint() {
  noSoundsHint.style.display = soundRows.children.length === 0 ? 'block' : 'none';
}

// ── Collect sound data from rows ──────────────────────────
function collectSounds() {
  return Array.from(soundRows.querySelectorAll('.sound-row')).map((row, i) => ({
    type: row.querySelector('.sound-type-select').value,
    delay_before_ms: parseInt(row.querySelector('.sound-delay').value) || 0,
    text_content: row.querySelector('.sound-text')?.value?.trim() ?? null,
    language: row.querySelector('.sound-lang')?.value ?? 'en-US',
    voice: row.querySelector('.sound-voice')?.value ?? VOICES[0]?.id,
    _fileInput: row.querySelector('.sound-file-input'),
    sort_order: i,
  }));
}

// ── Upload audio file for a sound ────────────────────────
async function uploadAudioFile(soundId, fileInput) {
  const file = fileInput?.files?.[0];
  if (!file) return null;
  const fd = new FormData();
  fd.append('file', file);
  fd.append('prefix', `audio/uploads/${soundId}`);
  const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
  if (!res.ok) return null;
  const { key } = await res.json();
  return key;
}

// ── Save subject (add or edit) ────────────────────────────
saveBtn.addEventListener('click', async () => {
  const title = titleInput.value.trim();
  if (!title) { titleInput.focus(); titleInput.style.borderColor = '#ef4444'; return; }
  titleInput.style.borderColor = '';

  saveBtn.disabled = true;
  saveBtn.textContent = 'Saving…';

  try {
    let subjectId = editingSubjectId;

    if (!subjectId) {
      // Create new subject
      const existing = document.querySelectorAll('#subjectList .subject-card').length;
      const res = await fetch('/api/admin/subjects', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ topic_id: topicId, title, sort_order: existing, image_key: uploadedImageKey }),
      });
      if (!res.ok) throw new Error('Failed to create subject');
      const sub = await res.json();
      subjectId = sub.id;
    } else {
      // Update existing title
      await fetch('/api/admin/subjects', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: subjectId, title }),
      });
    }

    // Save sounds
    const soundData = collectSounds();
    for (const s of soundData) {
      const payload = {
        subject_id: subjectId,
        type: s.type,
        sort_order: s.sort_order,
        delay_before_ms: s.delay_before_ms,
        text_content: s.type === 'text' ? s.text_content : null,
        language: s.language,
        voice: s.voice,
      };
      const soundRes = await fetch('/api/admin/sounds', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (soundRes.ok && s.type === 'file' && s._fileInput?.files?.[0]) {
        const sound = await soundRes.json();
        await uploadAudioFile(sound.id, s._fileInput);
      }
    }

    // Reload page to show updated list
    window.location.reload();

  } catch (err) {
    alert(err.message ?? 'Something went wrong');
    saveBtn.disabled = false;
    saveBtn.textContent = 'Save Subject';
  }
});

// ── Add sound row button ──────────────────────────────────
addSoundBtn.addEventListener('click', () => addSoundRow());

// ── Close modal ───────────────────────────────────────────
document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
document.getElementById('modalCancelBtn').addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && overlay.classList.contains('open')) closeModal();
});

// ── Open modal for new subject ────────────────────────────
document.getElementById('addSubjectBtn').addEventListener('click', () => openModal('add'));

// ── Delete subject ────────────────────────────────────────
document.querySelectorAll('.btn-danger').forEach(btn => {
  btn.addEventListener('click', async () => {
    const subjectId = btn.dataset.id;
    const title = btn.dataset.title;
    if (!confirm(`Delete "${title}" and all its sounds?`)) return;
    const res = await fetch('/api/admin/subjects', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: subjectId }),
    });
    if (res.ok) {
      btn.closest('.subject-card').remove();
      renumberCards();
      if (!document.querySelector('.subject-card')) {
        const el = document.createElement('div');
        el.id = 'emptyState';
        el.className = 'empty-state';
        el.innerHTML = 'No subjects yet — click <strong>+ Add Subject</strong> to get started.';
        document.getElementById('subjectList').prepend(el);
      }
    } else { alert('Failed to delete'); }
  });
});

function renumberCards() {
  document.querySelectorAll('#subjectList .subject-card').forEach((card, i) => {
    const num = card.querySelector('.card-num');
    if (num) num.textContent = i + 1;
  });
}
</script>

<style is:global>
  /* ── Page header ─────────────────────────────────────── */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 700;
    color: #475569;
  }
  .breadcrumb a { color: #64748b; text-decoration: none; }
  .breadcrumb a:hover { color: #1e293b; }
  .breadcrumb .sep { color: #cbd5e1; }
  .header-actions { display: flex; gap: 10px; }

  /* ── Buttons ─────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 9px 18px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    text-decoration: none;
    border: none;
    transition: background 0.15s, opacity 0.15s;
    white-space: nowrap;
  }
  .btn:disabled { opacity: 0.55; cursor: not-allowed; }
  .btn-primary { background: #4BA3FF; color: white; }
  .btn-primary:hover:not(:disabled) { background: #2f8de8; }
  .btn-ghost {
    background: white;
    color: #475569;
    border: 1.5px solid #e2e8f0;
  }
  .btn-ghost:hover:not(:disabled) { background: #f1f5f9; }
  .btn-danger { background: #fee2e2; color: #ef4444; }
  .btn-danger:hover:not(:disabled) { background: #fecaca; }
  .btn-sm { padding: 5px 12px; font-size: 13px; }

  /* ── Subject card (list row) ─────────────────────────── */
  .subject-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    margin-bottom: 12px;
    overflow: hidden;
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
  }
  .card-num {
    font-size: 13px;
    font-weight: 800;
    color: #94a3b8;
    min-width: 22px;
    flex-shrink: 0;
  }
  .card-thumb {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1.5px solid #e2e8f0;
  }
  .card-thumb-empty {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: #f1f5f9;
    border: 1.5px dashed #cbd5e1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: #94a3b8;
    flex-shrink: 0;
  }
  .card-meta {
    flex: 1;
    min-width: 0;
  }
  .card-title {
    font-size: 15px;
    font-weight: 800;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-sounds-count {
    font-size: 12px;
    color: #94a3b8;
    font-weight: 700;
    margin-top: 2px;
  }
  .card-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  /* ── Empty state ─────────────────────────────────────── */
  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: #94a3b8;
    font-size: 15px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  /* ── Modal overlay ───────────────────────────────────── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
    z-index: 500;
    align-items: flex-start;
    justify-content: center;
    padding: 24px 16px;
    overflow-y: auto;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 600px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    display: flex;
    flex-direction: column;
    margin: auto;
  }

  /* Modal header */
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1.5px solid #f1f5f9;
  }
  .modal-title {
    font-size: 18px;
    font-weight: 800;
    color: #1e293b;
    margin: 0;
  }
  .modal-close {
    background: none;
    border: none;
    color: #94a3b8;
    font-size: 18px;
    cursor: pointer;
    padding: 6px 8px;
    border-radius: 6px;
    font-family: inherit;
    line-height: 1;
  }
  .modal-close:hover { background: #f1f5f9; color: #475569; }

  /* Modal body */
  .modal-body {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow-y: auto;
    max-height: calc(85svh - 140px);
  }

  /* Modal footer */
  .modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 16px 24px;
    border-top: 1.5px solid #f1f5f9;
  }

  /* ── Form fields ─────────────────────────────────────── */
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field-label {
    font-size: 13px;
    font-weight: 700;
    color: #475569;
    margin-bottom: 0;
  }
  .required { color: #ef4444; }
  .field-input {
