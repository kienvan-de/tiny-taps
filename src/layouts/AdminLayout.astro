---
import '../styles/global.css';
import SquaresFour from 'phosphor-astro/SquaresFourBold.astro';
import ListBullets from 'phosphor-astro/ListBulletsBold.astro';
import Tag from 'phosphor-astro/TagBold.astro';
import SignOut from 'phosphor-astro/SignOutBold.astro';
import PawPrint from 'phosphor-astro/PawPrintBold.astro';
import List from 'phosphor-astro/ListBold.astro';
import X from 'phosphor-astro/XBold.astro';

interface Props {
  title?: string;
}

const { title = 'Dashboard' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Tiny Taps Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/bold/style.css"
    />
    <style>
      body {
        background: #f1f5f9;
        font-family: 'Nunito', sans-serif;
        font-size: 16px;
        margin: 0;
        padding: 0;
      }

      /* ─── Desktop shell ─────────────────────────────────── */
      .admin-shell {
        display: flex;
        min-height: 100vh;
      }

      /* ─── Mobile top bar (hidden on desktop) ────────────── */
      .mobile-header {
        display: none;
      }

      /* ─── Sidebar ───────────────────────────────────────── */
      .sidebar {
        width: 220px;
        background: #1e293b;
        color: white;
        padding: 24px 16px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
      }
      .sidebar-brand {
        font-size: 20px;
        font-weight: 800;
        margin-bottom: 32px;
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .sidebar-brand svg {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        color: #FF4B4B;
      }
      .sidebar-nav {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
      }
      .sidebar-nav a {
        color: #94a3b8;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        transition: background 0.15s, color 0.15s;
      }
      .sidebar-nav a svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }
      .sidebar-nav a:hover,
      .sidebar-nav a.active {
        background: #334155;
        color: white;
      }
      .sidebar-footer {
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid #334155;
      }
      .logout-btn {
        width: 100%;
        background: transparent;
        border: 1.5px solid #475569;
        color: #94a3b8;
        padding: 9px 12px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 700;
        font-family: inherit;
        transition: background 0.15s, color 0.15s;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .logout-btn svg {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
      }
      .logout-btn:hover {
        background: #334155;
        color: white;
      }

      /* ─── Main content ──────────────────────────────────── */
      .main-content {
        flex: 1;
        padding: 32px;
        overflow-y: auto;
        min-width: 0;
      }
      .page-title {
        font-size: 28px;
        font-weight: 800;
        color: #1e293b;
        margin: 0 0 24px;
      }

      /* ─── Drawer overlay (hidden by default) ────────────── */
      .drawer-overlay {
        display: none;
      }

      /* ═══════════════════════════════════════════════════════
         MOBILE ≤ 768px
         ═══════════════════════════════════════════════════════ */
      @media (max-width: 768px) {
        /* Show top bar */
        .mobile-header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          background: #1e293b;
          color: white;
          padding: 12px 16px;
          position: sticky;
          top: 0;
          z-index: 100;
        }
        .mobile-header .sidebar-brand {
          margin-bottom: 0;
          font-size: 18px;
        }
        .hamburger-btn {
          background: none;
          border: none;
          color: white;
          cursor: pointer;
          padding: 8px;
          border-radius: 8px;
          display: flex;
          align-items: center;
          justify-content: center;
          min-width: 44px;
          min-height: 44px;
        }
        .hamburger-btn svg {
          width: 24px;
          height: 24px;
        }
        .hamburger-btn:hover {
          background: #334155;
        }

        /* Hide the desktop sidebar */
        .admin-shell > .sidebar {
          display: none;
        }

        /* Drawer overlay */
        .drawer-overlay {
          display: none;
          position: fixed;
          inset: 0;
          z-index: 200;
        }
        .drawer-overlay.open {
          display: block;
        }
        .drawer-backdrop {
          position: absolute;
          inset: 0;
          background: rgba(0, 0, 0, 0.5);
        }
        .drawer-panel {
          position: absolute;
          top: 0;
          left: 0;
          bottom: 0;
          width: 280px;
          max-width: 85vw;
          background: #1e293b;
          color: white;
          padding: 24px 16px;
          display: flex;
          flex-direction: column;
          transform: translateX(-100%);
          transition: transform 0.25s ease;
          overflow-y: auto;
        }
        .drawer-overlay.open .drawer-panel {
          transform: translateX(0);
        }

        /* Drawer header with close button */
        .drawer-header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          margin-bottom: 24px;
        }
        .drawer-header .sidebar-brand {
          margin-bottom: 0;
        }
        .close-btn {
          background: none;
          border: none;
          color: #94a3b8;
          cursor: pointer;
          padding: 8px;
          border-radius: 8px;
          display: flex;
          align-items: center;
          justify-content: center;
          min-width: 44px;
          min-height: 44px;
        }
        .close-btn svg {
          width: 22px;
          height: 22px;
        }
        .close-btn:hover {
          background: #334155;
          color: white;
        }

        /* Drawer nav links — bigger touch targets */
        .drawer-panel .sidebar-nav a {
          padding: 14px 14px;
          font-size: 16px;
          min-height: 44px;
        }
        .drawer-panel .sidebar-nav a svg {
          width: 20px;
          height: 20px;
        }
        .drawer-panel .logout-btn {
          padding: 14px 14px;
          font-size: 15px;
          min-height: 44px;
        }

        /* Layout becomes vertical */
        .admin-shell {
          flex-direction: column;
        }

        /* Reduce padding on mobile */
        .main-content {
          padding: 20px 16px;
        }
        .page-title {
          font-size: 22px;
          margin-bottom: 16px;
        }
      }
    </style>
  </head>
  <body>
    <!-- ─── Mobile top bar ─────────────────────────────────── -->
    <header class="mobile-header">
      <a href="/admin/dashboard" class="sidebar-brand">
        <PawPrint color="#FF4B4B" />
        Tiny Taps
      </a>
      <button class="hamburger-btn" id="menuOpenBtn" aria-label="Open menu">
        <List />
      </button>
    </header>

    <!-- ─── Mobile slide-out drawer ────────────────────────── -->
    <div class="drawer-overlay" id="drawer">
      <div class="drawer-backdrop" id="drawerBackdrop"></div>
      <nav class="drawer-panel">
        <div class="drawer-header">
          <a href="/admin/dashboard" class="sidebar-brand">
            <PawPrint color="#FF4B4B" />
            Tiny Taps
          </a>
          <button class="close-btn" id="menuCloseBtn" aria-label="Close menu">
            <X />
          </button>
        </div>
        <ul class="sidebar-nav">
          <li>
            <a href="/admin/dashboard">
              <SquaresFour />
              Dashboard
            </a>
          </li>
          <li>
            <a href="/admin/topics">
              <ListBullets />
              Topics
            </a>
          </li>
          <li>
            <a href="/admin/tags">
              <Tag />
              Tags
            </a>
          </li>
        </ul>
        <div class="sidebar-footer">
          <form method="POST" action="/api/admin/logout">
            <button type="submit" class="logout-btn">
              <SignOut />
              Logout
            </button>
          </form>
        </div>
      </nav>
    </div>

    <!-- ─── Main shell ─────────────────────────────────────── -->
    <div class="admin-shell">
      <aside class="sidebar">
        <a href="/admin/dashboard" class="sidebar-brand">
          <PawPrint color="#FF4B4B" />
          Tiny Taps
        </a>
        <ul class="sidebar-nav">
          <li>
            <a href="/admin/dashboard">
              <SquaresFour />
              Dashboard
            </a>
          </li>
          <li>
            <a href="/admin/topics">
              <ListBullets />
              Topics
            </a>
          </li>
          <li>
            <a href="/admin/tags">
              <Tag />
              Tags
            </a>
          </li>
        </ul>
        <div class="sidebar-footer">
          <form method="POST" action="/api/admin/logout">
            <button type="submit" class="logout-btn">
              <SignOut />
              Logout
            </button>
          </form>
        </div>
      </aside>
      <main class="main-content">
        <h1 class="page-title">{title}</h1>
        <slot />
      </main>
    </div>

    <script>
      // Highlight active nav link (both desktop sidebar and drawer)
      const links = document.querySelectorAll('.sidebar-nav a');
      links.forEach(link => {
        if (window.location.pathname.startsWith(link.getAttribute('href') ?? '')) {
          link.classList.add('active');
        }
      });

      // Mobile drawer open/close
      const drawer = document.getElementById('drawer')!;
      const menuOpenBtn = document.getElementById('menuOpenBtn')!;
      const menuCloseBtn = document.getElementById('menuCloseBtn')!;
      const drawerBackdrop = document.getElementById('drawerBackdrop')!;

      function openDrawer() {
        drawer.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawer.classList.remove('open');
        document.body.style.overflow = '';
      }

      menuOpenBtn.addEventListener('click', openDrawer);
      menuCloseBtn.addEventListener('click', closeDrawer);
      drawerBackdrop.addEventListener('click', closeDrawer);

      // Close drawer on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && drawer.classList.contains('open')) {
          closeDrawer();
        }
      });
    </script>
  </body>
</html>
